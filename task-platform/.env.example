# Docker Compose project name (keeps volumes stable across rebuilds)
COMPOSE_PROJECT_NAME=task-platform

# Postgres
POSTGRES_DB=taskplatform
POSTGRES_USER=taskplatform
POSTGRES_PASSWORD=taskplatform

# Backend
JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Cookies
# For production behind HTTPS, set to true so the refresh cookie is only sent over TLS.
REFRESH_COOKIE_SECURE=false

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:8080

# Frontend build
VITE_API_URL=http://localhost:8000
