# =============================================================================
# .gitignore - CI/CD Pipeline
# =============================================================================

# Credenciales (NUNCA commitear)
config/.env
*.env
.env

# Base de datos SQLite
db/*.db
db/*.db-journal

# Logs
logs/
*.log

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Entornos virtuales
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporales
*.tmp
*.bak
*.old

# ISOs generados (muy grandes)
*.iso
