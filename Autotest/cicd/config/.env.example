# =============================================================================
# Variables de entorno para CI/CD Pipeline
# =============================================================================
# Ubicación: /home/YOUR_USER/cicd/config/.env
#
# IMPORTANTE: Este fichero contiene credenciales sensibles
# - NO commitear a Git
# - Añadir a .gitignore
# - Permisos: chmod 600 .env
# =============================================================================

# -----------------------------------------------------------------------------
# Credenciales Git
# -----------------------------------------------------------------------------
# Usar token de acceso personal en lugar de password cuando sea posible
GIT_PASSWORD=your_git_token_or_password_here

# -----------------------------------------------------------------------------
# Token de SonarQube
# -----------------------------------------------------------------------------
# Obtener de: sonar-project.properties (sonar.login) o generar nuevo en:
# https://YOUR_SONARQUBE_SERVER/account/security
SONAR_TOKEN=your_sonar_token_here

# -----------------------------------------------------------------------------
# Credenciales vCenter
# -----------------------------------------------------------------------------
# Usuario con permisos para:
# - Subir ficheros a datastore
# - Configurar VM (CD-ROM)
# - Encender VM
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=your_vcenter_password_here
