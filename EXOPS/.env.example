# Seguridad JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Entorno
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
# DEV_MODE=true omite la conexión real al vCenter (solo desarrollo)
DEV_MODE=false

# Base de datos
DATABASE_URL=sqlite+aiosqlite:///./data/exops.db

# Certificados SSL
SSL_CERT_PATH=certs/cert.pem
SSL_KEY_PATH=certs/key.pem

# vCenter cuenta de servicio para métricas en background (opcional)
# Si no se configuran, el dashboard solo guarda métricas cuando un usuario lo visita.
# VCENTER_SERVICE_HOST=vcenter.example.com
# VCENTER_SERVICE_USER=svc-exops@vsphere.local
# VCENTER_SERVICE_PASS=contraseña-segura
VCENTER_METRICS_INTERVAL_MINUTES=15
